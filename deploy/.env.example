# docker-compose.full.yml 使用（复制为 deploy/.env 后按需修改）
# 切勿将 .env 提交到 Git；本文件仅为占位符模板。

NUXT_PUBLIC_SITE_URL=https://www.example.com
NUXT_PUBLIC_CONSOLE_URL=https://www.example.com/console
SITE_URL=https://www.example.com

# 营销站 / Nginx 反代 Bearer；与 workbench-server/.env 的 SITE_API_TOKEN 保持一致
# SITE_API_TOKEN=change-me-to-a-long-random-secret

# 用户登录 JWT 签名；生产必须设置（与 workbench-server/.env 一致）
# JWT_SECRET=change-me-to-a-long-random-string

# ── 敏感配置加密（ai_service_configs / ai_preset_configs 的 api_key）──
# 设置后启动时自动加密库内明文 key；未设置则保持明文（开发可用 SITE_API_TOKEN 作 fallback）
# CONFIG_ENCRYPTION_KEY=change-me-to-a-long-random-string
# 离线生成 enc:v1: 密文（与后端 secret-cipher 一致）：
#   node deploy/encrypt-api-key.mjs sk-your-api-key
#   node deploy/encrypt-api-key.mjs --sql ai_service_configs 1 sk-your-api-key
# 批量密钥轮换（旧 key → CONFIG_ENCRYPTION_KEY）：
#   node deploy/reencrypt-api-keys.mjs --from-secret OLD_KEY --dry-run
#   node deploy/reencrypt-api-keys.mjs --from-secret OLD_KEY --apply

# ── 数据库（默认 SQLite；生产可切 MySQL）────────────────────────
# DB_DRIVER=sqlite
# DB_DRIVER=mysql
# DATABASE_URL=mysql://huohuo:secret@mysql:3306/huohuo_drama
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_USER=huohuo
# MYSQL_PASSWORD=secret
# MYSQL_DATABASE=huohuo_drama
# DB_POOL_SIZE=10
# DB_AUTO_INIT=true

# ── MySQL SQL 文件导入（可选）──────────────────────────────────
# 设为 true 时，容器启动前会将 workbench-data 下的 SQL 文件导入 MySQL
# MYSQL_IMPORT_SQL=false
# MYSQL_IMPORT_FILE=/app/workbench-data/huohuo_drama.sql

# 本地开发 MySQL 示例（workbench-server/.env 同理）：
# DB_DRIVER=mysql
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/huohuo_drama

# ── 初始管理员（DB_AUTO_INIT=true 时使用）──────────────────────
# 留空则不自动创建，部署后通过 web 控制台或 SQL 手工建立
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-password
# BOOTSTRAP_ADMIN_OVERWRITE=false   # 设为 true/1/yes/on 强制覆盖同 username 的密码
