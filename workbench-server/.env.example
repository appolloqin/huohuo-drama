# 复制为 workbench-server/.env 后按需修改（tsx 不会自动加载，由 load-env.ts 读取）
# 切勿将 .env 提交到 Git；本文件仅为占位符模板。

# ── 数据库（默认 SQLite）────────────────────────────────────
# DB_DRIVER=sqlite
# DB_PATH=../workbench-data/huohuo_drama.db
# DATA_PATH=../workbench-data
# DB_AUTO_INIT=true

# ── MySQL（生产或本地联调）──────────────────────────────────
# DB_DRIVER=mysql
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/huohuo_drama
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=huohuo_drama
# DB_POOL_SIZE=10
# DB_AUTO_INIT=true

# ── 服务 ────────────────────────────────────────────────────
# PORT=18555

# ── 鉴权（生产必须修改）──────────────────────────────────────
# 用户登录 JWT 签名；未设置时使用开发默认值，生产环境务必覆盖
# JWT_SECRET=change-me-to-a-long-random-string

# ── FFmpeg（视频合成 / 导出拼接）────────────────────────────
# Windows 建议设为 ffmpeg.exe 完整路径；也可设为 bin 目录（会自动补全 .exe）
# FFMPEG_PATH=D:/ProgramX64/ffmpeg702/bin/ffmpeg.exe
# FFPROBE_PATH=D:/ProgramX64/ffmpeg702/bin/ffprobe.exe

# ── 静帧工作台 BGM（无配音镜头 / 拼接归一化）────────────────
# 不设置则首次使用时在 static/bgm/ 生成默认氛围循环
# FRAME_SLIDESHOW_BGM_PATH=D:/assets/my-bgm-loop.mp3
# FRAME_SLIDESHOW_BGM_VOLUME=0.32

# ── 站点 / 展示（可选）──────────────────────────────────────
# SITE_URL=http://localhost
# 营销站 / Nginx 反代 Bearer；与 deploy/.env、site 的 NUXT_SITE_API_TOKEN 保持一致
# SITE_API_TOKEN=change-me-to-a-long-random-secret

# ── 敏感配置加密（ai_service_configs / ai_preset_configs 的 api_key）──
# 设置后启动时自动加密库内明文 key；未设置则保持明文（开发可用 SITE_API_TOKEN 作 fallback）
# CONFIG_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ── 初始管理员（DB_AUTO_INIT=true 时使用，user 表为空时创建）────
# 不设置则不自动创建管理员（部署后通过 web 控制台或 SQL 手工建立）
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-password
# BOOTSTRAP_ADMIN_OVERWRITE=false   # 设为 true/1/yes/on 强制覆盖同 username 的密码
