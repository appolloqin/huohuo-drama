{
  "name": "huohuo-drama-workbench",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/ensure-node-lts.mjs",
    "prebuild": "node ./scripts/ensure-node-lts.mjs",
    "pregenerate": "node ./scripts/ensure-node-lts.mjs",
    "prepreview": "node ./scripts/ensure-node-lts.mjs",
    "dev": "node ./scripts/ensure-node-lts.mjs && node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs dev --port 28555",
    "build": "node ./scripts/ensure-node-lts.mjs && node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs build",
    "generate": "node ./scripts/ensure-node-lts.mjs && node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "node ./scripts/ensure-node-lts.mjs && node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs preview",
    "smoke:proxy": "node ./scripts/smoke-proxy.mjs",
    "postinstall": "node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs prepare"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "dependencies": {
    "lucide-vue-next": "^0.577.0",
    "nuxt": "^3.21.8",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vue-sonner": "^1.3.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vue-tsc": "^3.3.5"
  }
}
